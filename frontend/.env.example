# Vite Frontend Environment Variables (Template)
# Copy this file to '.env' and fill in the values.

# The public URL of the backend API server.
# For local development: leave empty to use the /api proxy, or set to http://localhost:5000
# For production: set to your deployed backend URL (e.g., https://auth-token-1x6w.onrender.com)
VITE_API_URL=https://auth-token-1x6w.onrender.com
